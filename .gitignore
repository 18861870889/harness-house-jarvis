# Harness-House Git Ignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# Node / frontend
node_modules/
.vite/
coverage/

# Config with secrets
config.yaml
*.env
.env

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local Home Assistant discovery snapshots
ha-*-summary.json
ha-*-snapshot.json
data/*.local.json
data/*.local.json.bak-*
data/*.local.jsonl

# Virtual env
venv/
.venv/
env/
